        "pythonCode": "raw = _input.item.json['output']\ntext = raw.replace('###','').replace('**','')\n\ncontent = 'MARKET TRENDS & CONDITIONS\\n' + '='*50 + '\\n\\n' + text\n\nreturn {'json': {'section': 'trends', 'content': content}}"
