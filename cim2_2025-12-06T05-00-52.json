    {
      "parameters": {
        "language": "python",
        "pythonCode": "import json\n\nraw = _input.item.json['output']\ndata = json.loads(raw) if isinstance(raw, str) else raw\n\ncomps = data.get('competitors', [])\n\ntable = 'COMPETITOR ANALYSIS\\n' + '='*50 + '\\n\\n'\ntable += 'Name\\tServices\\tOnline\\tPositioning\\tStrengths\\tWeaknesses\\n'\ntable += '---\\t---\\t---\\t---\\t---\\t---\\n'\n\nfor c in comps:\n    table += f\"{c.get('name','')}\\t{c.get('services','')}\\t{c.get('online','')}\\t{c.get('positioning','')}\\t{c.get('strengths','')}\\t{c.get('weaknesses','')}\\n\"\n\nreturn {'json': {'section': 'competitors', 'content': table}}"
      },
